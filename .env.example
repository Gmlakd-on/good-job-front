# ──────────────────────────────────────────────────────────
# 참 잘했어요 — 프론트엔드 환경 변수
# Vercel: Project Settings > Environment Variables 에 직접 입력
# 로컬: 이 파일을 .env.local 로 복사 후 값 채우기
# ──────────────────────────────────────────────────────────

# Supabase (필수) — 브라우저 인증용. anon/publishable 키만 사용.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# 백엔드 API 주소 (필수) — /api/* 요청이 이 주소로 프록시됨
# 로컬: http://localhost:3001 / 프로덕션: 백엔드 Vercel 도메인
API_BASE_URL=http://localhost:3001

# 사이트 URL (sitemap, OG 등)
NEXT_PUBLIC_SITE_URL=https://your-frontend.vercel.app

# Supabase Kakao OAuth provider id (선택)
NEXT_PUBLIC_KAKAO_AUTH_PROVIDER=kakao
